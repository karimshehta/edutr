import { TextStyle } from 'react-native';

// Typography scale following modern design systems (Inter/SF Pro)
export const typography: Record<string, TextStyle> = {
  // Display
  display: { fontSize: 40, fontWeight: '700', lineHeight: 48, letterSpacing: -1 },

  // Headings
  h1: { fontSize: 32, fontWeight: '700', lineHeight: 40, letterSpacing: -0.8 },
  h2: { fontSize: 24, fontWeight: '700', lineHeight: 32, letterSpacing: -0.5 },
  h3: { fontSize: 20, fontWeight: '600', lineHeight: 28, letterSpacing: -0.3 },
  h4: { fontSize: 18, fontWeight: '600', lineHeight: 24, letterSpacing: -0.2 },
  h5: { fontSize: 16, fontWeight: '600', lineHeight: 22, letterSpacing: -0.1 },

  // Body
  bodyLarge: { fontSize: 17, fontWeight: '400', lineHeight: 24, letterSpacing: 0 },
  body:       { fontSize: 15, fontWeight: '400', lineHeight: 22, letterSpacing: 0 },
  bodyMedium: { fontSize: 15, fontWeight: '500', lineHeight: 22, letterSpacing: 0 },
  bodySmall:  { fontSize: 14, fontWeight: '400', lineHeight: 20, letterSpacing: 0 },

  // Labels / captions
  label:         { fontSize: 13, fontWeight: '500', lineHeight: 18, letterSpacing: 0.2 },
  caption:       { fontSize: 13, fontWeight: '400', lineHeight: 18, letterSpacing: 0 },
  captionMedium: { fontSize: 13, fontWeight: '500', lineHeight: 18, letterSpacing: 0 },

  // Small — widely referenced in screens, was missing (caused silent spread of undefined)
  small: { fontSize: 12, fontWeight: '400', lineHeight: 16, letterSpacing: 0 },

  // Tiny
  tiny:       { fontSize: 11, fontWeight: '400', lineHeight: 16, letterSpacing: 0.1 },
  tinyMedium: { fontSize: 11, fontWeight: '500', lineHeight: 16, letterSpacing: 0.2 },

  // Interactive
  button:      { fontSize: 16, fontWeight: '600', lineHeight: 20, letterSpacing: 0.2 },
  buttonSmall: { fontSize: 14, fontWeight: '600', lineHeight: 18, letterSpacing: 0.1 },
  link: { fontSize: 15, fontWeight: '500', lineHeight: 22, letterSpacing: 0, textDecorationLine: 'underline' },

  // Special
  overline: { fontSize: 11, fontWeight: '700', lineHeight: 16, letterSpacing: 1.5, textTransform: 'uppercase' },
  tabLabel: { fontSize: 11, fontWeight: '600', lineHeight: 14, letterSpacing: 0.1 },
};
